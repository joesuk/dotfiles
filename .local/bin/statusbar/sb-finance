#!/bin/sh
eth=$(curl -s  "https://min-api.cryptocompare.com/data/pricemulti?fsyms=ETH,BTC&tsyms=USD&api_key=$(echo $APIKEY)" | jq '.ETH.USD')
btc=$(curl -s  "https://min-api.cryptocompare.com/data/pricemulti?fsyms=ETH,BTC&tsyms=USD&api_key=$(echo $APIKEY)" | jq '.BTC.USD')
vtsax_chase=1105.228
vtsax_v=193.634
vtiax_v=1290.468
vtsax=$(bash ticker.sh VTSAX)
vtiax=$(bash ticker.sh VTIAX)
#echo "vtsax"
#echo "($vtsax_chase + $vtsax_v)*$vtsax" | bc | cut -c1-4
#echo "vtiax"
#echo "$vtiax_v*$vtiax" | bc | cut -c1-4
#echo "eth"
#echo "3.82947*$eth" | bc | cut -c1-3
#echo "btc"
#echo "0.116346*$btc" | bc | cut -c1-3
#echo "($vtsax_chase + $vtsax_v)*$vtsax + $vtiax_v*$vtiax+3.82947*$eth+0.116346*$btc" | bc | cut -c1-3

# Compute raw totals
vtsax_total=$(echo "($vtsax_chase + $vtsax_v) * $vtsax" | bc)
vtiax_total=$(echo "$vtiax_v * $vtiax" | bc)
eth_total=$(echo "3.82947 * $eth" | bc)
btc_total=$(echo "0.116346 * $btc" | bc)
total=$(echo "$vtsax_total + $vtiax_total + $eth_total + $btc_total" | bc)

# Function to round to nearest thousand and add 'k'
format_k() {
    rounded=$(echo "$1" | awk '{ printf("%d", int(($1 + 500)/1000)) }')
    echo "${rounded}k"
}

# Format all values
vtsax_fmt=$(format_k $vtsax_total)
vtiax_fmt=$(format_k $vtiax_total)
eth_fmt=$(format_k $eth_total)
btc_fmt=$(format_k $btc_total)
total_fmt=$(format_k $total)

# Output
echo "VTSAX: $vtsax_fmt"
echo "VTIAX: $vtiax_fmt"
echo "ETH:   $eth_fmt"
echo "BTC:   $btc_fmt"
echo "Total: $total_fmt"
